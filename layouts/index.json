[
  {{ range $index, $page := where site.RegularPages "Type" "recipes" }}
    {{ if gt $index 0 }},{{ end }}
    {
      "title": {{ .Title | jsonify }},
      "url": {{ .RelPermalink | jsonify }},
      "time_total": {{ .Params.time_total | jsonify }},
      "ingredients": {{ .Params.ingredients | jsonify }},
      "cuisine": {{ delimit .Params.cuisine " " | lower | jsonify }},
      "category": {{ delimit .Params.category " " | lower | jsonify }},
      "occasion": {{ if .Params.occasion }}{{ delimit .Params.occasion " " | lower | jsonify }}{{ else }}""{{ end }},
      "diet": {{ if .Params.diet }}{{ delimit .Params.diet " " | lower | jsonify }}{{ else }}""{{ end }}
    }
  {{ end }}
]
